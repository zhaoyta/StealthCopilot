{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "test:unit": "vitest run",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.ts,.js"
  },
  "config": {
    "commitizen": {
      "path": "stealthcopilot/frontend/node_modules/cz-git"
    }
  },
  "lint-staged": {
    "*.go": "golangci-lint run"
  },
  "dependencies": {
    "lucide-vue-next": "^1.0.0",
    "vue": "^3.2.37",
    "vue-i18n": "^9.14.5"
  },
  "devDependencies": {
    "@babel/types": "^7.18.10",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@intlify/eslint-plugin-vue-i18n": "^3.2.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-vue": "^3.0.3",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.5.0",
    "commitizen": "^4.3.2",
    "cz-git": "^1.13.1",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^9.33.0",
    "husky": "^9.1.7",
    "jsdom": "^22.1.0",
    "lint-staged": "^17.0.7",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^4.6.4",
    "vite": "^3.0.7",
    "vitest": "^0.34.6",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^1.8.27"
  }
